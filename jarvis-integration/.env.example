# JARVIS + Kimi K2.5 + Chief of Staff Configuration
# Copy this to .env and fill in your values

# ============================================================================
# ORIGINAL JARVIS CONFIGURATION (Unchanged)
# ============================================================================

# Your Anthropic API key (for Claude)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Your Fish Audio API key (for JARVIS voice)
# Get from: https://fish.audio/
FISH_API_KEY=your-fish-audio-key-here

# Your name - JARVIS will address you with this
USER_NAME=sir

# Optional: Specific calendar accounts (comma-separated)
# Leave empty to auto-discover all calendars
CALENDAR_ACCOUNTS=

# ============================================================================
# NEW INTEGRATION CONFIGURATION
# ============================================================================

# Kimi K2.5 API Configuration
# You can use either OpenRouter or direct Kimi API

# Option 1: OpenRouter (recommended)
# Get key from: https://openrouter.ai/
KIMI_API_KEY=sk-or-your-openrouter-key-here
KIMI_API_PROVIDER=openrouter
KIMI_MODEL=kimi-k2-5

# Option 2: Direct Kimi API
# Get key from: https://api.kimi.ai/
# KIMI_API_KEY=your-direct-kimi-key-here
# KIMI_API_PROVIDER=direct
# KIMI_API_URL=https://api.kimi.ai/v1

# ============================================================================
# CHIEF OF STAFF CONFIGURATION (Memory + Obsidian Integration)
# ============================================================================

# Path to your Obsidian vault
# Must be a valid Obsidian vault with a .obsidian folder
OBSIDIAN_VAULT_PATH=~/Obsidian

# Daily budget for LLM usage ($)
# This limits spending on Kimi + Claude combined
# Default: 50 (allows ~150,000 tokens for typical usage)
DAILY_BUDGET_LIMIT=50.0

# Budget alert threshold (as percentage, 0.0-1.0)
# Alert when budget spent reaches this percentage
BUDGET_ALERT_THRESHOLD=0.75

# ============================================================================
# SERVICE AUTOMATION CONFIGURATION (CRM + Sales Pipeline)
# ============================================================================

# Google Sheets integration (optional - for external CRM sync)
# Get from: https://console.developers.google.com/
GOOGLE_SHEETS_API_KEY=

# Mailgun integration (optional - for email prospecting)
# Get from: https://mailgun.com/
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Calendly integration (optional - for meeting scheduling)
# Get from: https://calendly.com/settings/integrations
CALENDLY_API_KEY=
CALENDLY_CALENDAR_URL=

# Default proposal templates location
# Can be local directory or Google Drive folder
PROPOSAL_TEMPLATES_PATH=./proposal_templates

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Where to store the integration databases
# Default: same directory as server.py
ROUTING_METRICS_DB=./routing_metrics.db
CHIEF_OF_STAFF_DB=./chief_of_staff.db
SERVICE_AUTOMATION_DB=./service_automation.db

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode (more verbose logging)
DEBUG=false

# Max tokens for Kimi responses
# Kimi supports up to 200K context
KIMI_MAX_TOKENS=4096

# Max tokens for Claude responses  
CLAUDE_MAX_TOKENS=2048

# ============================================================================
# NOTES
# ============================================================================
#
# Required Keys:
# - ANTHROPIC_API_KEY (original JARVIS)
# - FISH_API_KEY (original JARVIS)
# - KIMI_API_KEY (new integration)
# - OBSIDIAN_VAULT_PATH (new integration)
#
# Optional Keys:
# - GOOGLE_SHEETS_API_KEY (for external CRM)
# - MAILGUN_API_KEY (for email)
# - CALENDLY_API_KEY (for meetings)
#
# Budget Management:
# - DAILY_BUDGET_LIMIT: Prevents overspending
# - Default $50/day allows ~150K tokens
# - At 70% Kimi / 30% Claude split
# - Saves ~90% vs all Claude
#
# Obsidian Vault:
# - Must be an existing Obsidian vault
# - Must have .obsidian folder
# - Will create JARVIS_MEMORIES/ and JARVIS_DECISIONS/ directories
# - Human-readable markdown files
# - Also backed by SQLite for fast search
#
