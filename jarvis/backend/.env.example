# JARVIS Configuration

# Anthropic Claude API Key (required)
ANTHROPIC_API_KEY=sk-

# Kimi K2.5 API Key (optional - for multi-provider routing)
KIMI_API_KEY=

# Vault and Memory Paths
VAULT_PATH=/Users/abundance/.openclaw/workspace/vault
MEMORY_PATH=/Users/abundance/.openclaw/workspace/memory

# Cost Configuration
BUDGET_DAILY=50.0
KIMI_COST_PER_1M=0.50
CLAUDE_COST_PER_1M=3.00

# Logging
LOG_LEVEL=info

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Features (enable/disable)
ENABLE_VOICE=true
ENABLE_VAULT=true
ENABLE_SERVICE_AUTOMATION=true
ENABLE_NEURAL_ROUTING=true

# Timeouts
REQUEST_TIMEOUT_SEC=60
VAULT_SEARCH_LIMIT=10
