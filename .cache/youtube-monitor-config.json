{
  "job_name": "youtube-comment-monitor",
  "description": "Monitor Concessa Obvius YouTube channel for new comments, categorize, auto-respond, and log",
  "schedule": "*/30 * * * *",
  "schedule_human": "Every 30 minutes",
  "script": ".cache/youtube_comment_monitor.py",
  "channel": {
    "name": "Concessa Obvius",
    "id": "UCa_mZVVqV5Aq48a0MnIjS-w"
  },
  "environment": {
    "YOUTUBE_API_KEY": "SET_YOUR_API_KEY_HERE"
  },
  "output": {
    "comments_log": ".cache/youtube-comments.jsonl",
    "state_file": ".cache/youtube-monitor-state.json"
  },
  "categories": {
    "questions": {
      "patterns": [
        "how do i",
        "what is",
        "where to start",
        "cost",
        "timeline"
      ],
      "action": "auto_respond_with_template"
    },
    "praise": {
      "patterns": [
        "amazing",
        "inspiring",
        "thank you",
        "love"
      ],
      "action": "auto_respond_with_template"
    },
    "spam": {
      "patterns": [
        "crypto",
        "bitcoin",
        "mlm",
        "click here"
      ],
      "action": "flag_and_hide"
    },
    "sales": {
      "patterns": [
        "partnership",
        "collaborate",
        "sponsorship"
      ],
      "action": "flag_for_review"
    }
  },
  "response_templates": {
    "questions": "Thanks for the question! Here's how to get started: [CUSTOMIZED_ANSWER]. Check out [RELEVANT_LINK] for more details.",
    "praise": "Thank you so much! 🙏 This means everything to us. Keep supporting and we'll keep creating great content!"
  },
  "notifications": {
    "flagged_comments": true,
    "summary_report": true,
    "report_channel": "discord"
  }
}
