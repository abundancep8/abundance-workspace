{
  "channel": {
    "name": "Concessa Obvius",
    "channelId": "UCzPlaceHolderID",
    "checkInterval": 30
  },
  "youtube_api": {
    "apiKey": "${YOUTUBE_API_KEY}",
    "baseUrl": "https://www.googleapis.com/youtube/v3"
  },
  "categories": {
    "questions": {
      "patterns": ["how do i", "how can i", "what is", "where can", "cost", "price", "timeline", "start", "tools"],
      "autoRespond": true,
      "maxResponses": 1000
    },
    "praise": {
      "patterns": ["amazing", "inspiring", "love it", "thank you", "grateful", "awesome", "excellent"],
      "autoRespond": true,
      "maxResponses": 1000
    },
    "spam": {
      "patterns": ["crypto", "bitcoin", "nft", "mlm", "forex", "dropshipping", "click here"],
      "autoRespond": false,
      "action": "delete"
    },
    "sales": {
      "patterns": ["partnership", "collaboration", "sponsor", "advertise", "affiliate"],
      "autoRespond": false,
      "action": "flag"
    }
  },
  "responses": {
    "questions": [
      "Thanks for your question! I cover this in detail in our resources—check the linked guide in the channel description.",
      "Great question! This is addressed in our latest video. Watch for the full breakdown.",
      "Happy to help! Our FAQ section covers this. See the pinned comment for the link."
    ],
    "praise": [
      "Thank you so much! Your support means everything. More coming soon.",
      "Comments like this fuel the mission. Grateful for you.",
      "This is exactly why we do this. Thank you for believing in it."
    ]
  },
  "logging": {
    "logFile": ".cache/youtube-comments.jsonl",
    "stateFile": ".cache/youtube-monitor-state.json",
    "archiveFrequency": "weekly"
  }
}
